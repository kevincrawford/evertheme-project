# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=evertheme
POSTGRES_PASSWORD=evertheme_secret
POSTGRES_DB=evertheme
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://evertheme:evertheme_secret@db:5432/evertheme

# ── Encryption (Fernet key for storing PM credentials) ───────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-generate-with-fernet

# ── LLM — Server defaults ─────────────────────────────────────────────────────
# These are the fallback settings used when a user has not configured their own
# LLM provider in the UI. Individual users can always override these at runtime.
#
# DEFAULT_LLM_PROVIDER controls which provider is used by default.
# Supported values: openai | anthropic | azure_openai | ollama
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o

# ── LLM — API keys (server-level fallback) ────────────────────────────────────
# Set the key for your default provider. Users who supply their own key in the
# UI will use theirs instead; these are only used when no per-user key exists.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
OLLAMA_BASE_URL=http://localhost:11434

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost
